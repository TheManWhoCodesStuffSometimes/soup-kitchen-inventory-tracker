# Copy to .env.local for local development (with `vercel dev`)
# Production values live in Vercel project env vars.

# Auth
APP_PASSWORD=change-me
SESSION_SECRET=generate-32-plus-random-chars

# Neon (auto-injected by Vercel integration in production)
DATABASE_URL=postgres://...

# Vercel Blob (auto-injected by Vercel integration in production)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# n8n cascade webhook
N8N_CASCADE_WEBHOOK_URL=https://thayneautomations.app.n8n.cloud/webhook/cascade-analyze-item
N8N_CASCADE_WEBHOOK_SECRET=generate-32-plus-random-chars
